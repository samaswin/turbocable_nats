# Development / CI image for running the turbocable_nats gem test suite inside the
# docker compose stack. Not published to any registry.
FROM ruby:3.3-slim

# Install OS dependencies
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Pre-install gems from Gemfile (leverages layer caching)
COPY Gemfile Gemfile.lock* turbocable_nats.gemspec ./
COPY lib/turbocable/version.rb lib/turbocable/version.rb

RUN bundle install --jobs 4 --retry 3

# The full source tree is volume-mounted at runtime so we don't COPY it here.
CMD ["bundle", "exec", "rspec"]
